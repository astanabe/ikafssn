+     15,  0, 10,  3, 13, 15, 15,  2, 12, 15, 15,  8, 15,  9, 14, 15,
+     15, 15,  6,  4,  1, 15, 11,  5, 15,  7, 15, 15, 15, 15, 15, 15,
